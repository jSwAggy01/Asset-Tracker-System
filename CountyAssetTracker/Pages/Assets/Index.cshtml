@page
@model CountyAssetTracker.Pages.Assets.IndexModel
@{
    ViewData["Title"] = "All Assets";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Asset Inventory</h1>
    <a href="/Assets/Create" class="btn btn-primary">Add New Asset</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Asset Name</th>
                    <th>Serial Number</th>
                    <th>Purchase Date</th>
                    <th>Location</th>
                    <th>Building</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var asset in Model.Assets)
                {
                    <tr>
                        <td>@asset.AssetID</td>
                        <td>@asset.AssetName</td>
                        <td><code>@asset.SerialNumber</code></td>
                        <td>@asset.PurchaseDate.ToString("MMM dd, yyyy")</td>
                        <td>@asset.LocationName</td>
                        <td>@asset.Building</td>
                        <td>
                            <span class="badge @(asset.Status == "Active" ? "bg-success" : asset.Status == "Maintenance" ? "bg-warning text-dark" : asset.Status == "Inactive" ? "bg-secondary" : "bg-danger")">
                                @asset.Status
                            </span>
                        </td>
                        <td>
                            <a href="/Assets/Edit/@asset.AssetID" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a href="/Assets/UpdateStatus/@asset.AssetID" class="btn btn-sm btn-outline-warning">Status</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3 text-muted">
    <small>Showing @Model.Assets.Count() assets | Data retrieved using SQL JOIN query</small>
</div>
